---
import { site } from '../data/site';
---

<section class="hero">
  <div class="grid-bg" aria-hidden="true"></div>

  <div class="container hero-grid">
    <div class="hero-copy">
      <span class="eyebrow">portfólio · {new Date().getFullYear()}</span>
      <h1 class="hero-title">
        <span class="hero-given">Marcus</span>
        <span class="hero-family">Bragantini</span>
      </h1>
      <p class="lead">{site.shortBio}</p>

      <ul class="meta">
        <li><strong>Base</strong><span>{site.location}</span></li>
        <li><strong>Foco</strong><span>Automação · CAD · Front-end</span></li>
        <li><strong>Status</strong><span class="dot dot-on">disponível para projetos</span></li>
      </ul>

      <div class="cta">
        <a href="/experiencia" class="btn btn-primary">Ver experiência</a>
        <a href="/contato" class="btn btn-ghost">Falar comigo</a>
      </div>
    </div>

    <figure class="hero-photo">
      <div class="photo-frame">
        <img src={site.hero} alt={site.name} loading="eager" decoding="async" />
        <span class="frame-tick" aria-hidden="true">Rio · BR</span>
      </div>
      <figcaption class="photo-tag">
        <span class="tag-line"></span>
        <span>Em campo, próximo dos painéis.</span>
      </figcaption>
    </figure>
  </div>
</section>

<style>
  .hero {
    position: relative;
    isolation: isolate;
    padding-block: clamp(var(--space-7), 8vw, var(--space-10));
    overflow: hidden;
  }
  .grid-bg {
    position: absolute;
    inset: 0;
    z-index: -1;
    background-image:
      linear-gradient(var(--border-soft) 1px, transparent 1px),
      linear-gradient(90deg, var(--border-soft) 1px, transparent 1px);
    background-size: 56px 56px;
    mask-image: radial-gradient(ellipse at 70% 30%, #000 30%, transparent 80%);
    -webkit-mask-image: radial-gradient(ellipse at 70% 30%, #000 30%, transparent 80%);
    opacity: 0.7;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    gap: clamp(var(--space-6), 4vw, var(--space-8));
    align-items: center;
  }

  .hero-title {
    font-size: clamp(2.5rem, 6.5vw, 5rem);
    line-height: 0.95;
    letter-spacing: -0.035em;
    margin-block: var(--space-4) var(--space-5);
  }
  .hero-given { display: block; font-weight: 600; color: var(--ink-2); }
  .hero-family {
    display: block;
    font-weight: 800;
    color: var(--ink);
  }
  .hero-family::after {
    content: '.';
    color: var(--accent);
  }

  .meta {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-4);
    margin-block: var(--space-6);
    padding-top: var(--space-5);
    border-top: 1px solid var(--border);
  }
  .meta li {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .meta strong {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--ink-soft);
  }
  .meta span { font-size: var(--step--1); color: var(--ink); }
  .dot {
    position: relative;
    padding-left: 1rem;
  }
  .dot::before {
    content: '';
    position: absolute;
    left: 0; top: 50%;
    width: 0.55rem; height: 0.55rem;
    transform: translateY(-50%);
    border-radius: 50%;
    background: var(--success);
    box-shadow: 0 0 0 0 color-mix(in oklab, var(--success) 60%, transparent);
    animation: pulse 1.8s var(--ease) infinite;
  }
  @keyframes pulse {
    0% { box-shadow: 0 0 0 0 color-mix(in oklab, var(--success) 55%, transparent); }
    70% { box-shadow: 0 0 0 8px transparent; }
    100% { box-shadow: 0 0 0 0 transparent; }
  }

  .cta { display: flex; gap: var(--space-3); flex-wrap: wrap; }

  /* foto com moldura técnica */
  .hero-photo {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .photo-frame {
    position: relative;
    aspect-ratio: 4 / 5;
    background: var(--surface);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-lg);
    border: 1px solid var(--border);
  }
  .photo-frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
    filter: contrast(1.02) saturate(0.9);
    transition: transform var(--dur-slow) var(--ease);
  }
  .photo-frame:hover img { transform: scale(1.02); }
  .photo-frame::before {
    content: '';
    position: absolute;
    inset: 12px;
    border: 1px solid rgba(255, 255, 255, 0.35);
    border-radius: calc(var(--radius-lg) - 4px);
    pointer-events: none;
    mix-blend-mode: overlay;
  }
  .frame-tick {
    position: absolute;
    bottom: 0.85rem;
    left: 0.85rem;
    padding: 0.35rem 0.6rem;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    background: var(--ink);
    color: var(--surface);
    border-radius: 999px;
  }

  .photo-tag {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--ink-soft);
  }
  .tag-line {
    flex: 1;
    height: 1px;
    background: var(--border);
  }

  @media (max-width: 820px) {
    .hero-grid { grid-template-columns: 1fr; }
    .hero-photo { order: -1; max-width: 22rem; }
    .meta { grid-template-columns: 1fr 1fr; }
  }
</style>
