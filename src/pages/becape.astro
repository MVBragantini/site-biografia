---
import Base from '../layouts/Base.astro';
import { site } from '../data/site';
---

<Base title={`BECAPE — ${site.name}`}>
  <section class="section">
    <div class="container-narrow center">
      <span class="eyebrow">/becape</span>
      <h1>Em construção.</h1>
      <p class="lead">
        Aqui vai ficar meu acesso rápido a manuais (CFW, IHMs, drives) e o álbum
        de fotos de campo. A próxima fase do projeto liga essa página a um painel
        em <code>/admin</code>, onde adiciono novos manuais e fotos direto pelo navegador.
      </p>
      <div class="next">
        <h2>Próximos passos</h2>
        <ul>
          <li>Listagem dinâmica de manuais (nome, fabricante, link PDF)</li>
          <li>Galeria de fotos com categorias</li>
          <li>Busca por equipamento</li>
        </ul>
      </div>
      <a href="/" class="btn btn-ghost">← Voltar à página inicial</a>
    </div>
  </section>
</Base>

<style>
  .center { text-align: left; }
  h1 { font-size: var(--step-5); margin-block: var(--space-3) var(--space-5); }
  code {
    font-family: var(--font-mono);
    background: var(--surface);
    padding: 0.1rem 0.4rem;
    border-radius: 4px;
    border: 1px solid var(--border);
    font-size: 0.92em;
  }
  .next {
    margin-block: var(--space-7);
    padding: var(--space-5);
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
  }
  .next h2 {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--ink-soft);
    margin-bottom: var(--space-3);
  }
  .next ul {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .next li {
    padding-left: 1.2rem;
    position: relative;
    color: var(--ink-2);
  }
  .next li::before {
    content: '▸';
    position: absolute;
    left: 0; color: var(--accent);
  }
</style>
